# ──────────────────────────────────────────────────
# AURA Backend — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────

# Supabase project URL (found in Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (found in Supabase Dashboard → Settings → API → service_role key)
SUPABASE_KEY=your-supabase-service-role-key-here

# URL of the AURA LLM microservice (/generate endpoint)
# For local dev: http://localhost:7860/generate
# For production (HF Spaces): https://your-username-aura.hf.space/generate
AURA_URL=https://mayank214-aura.hf.space/generate

# Comma-separated list of allowed frontend origins (CORS)
# Add your Vercel URL here for production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
